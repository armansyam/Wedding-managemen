# Copy to .env and set secure credentials
# NEVER commit .env to version control!

# Admin credentials (required)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Session secret (required) - use a long random string
SESSION_SECRET=your-super-secret-random-string-here

# Server port
PORT=3000

# Node environment (set to 'production' in production)
NODE_ENV=development

# Base URL for generating links (e.g., review links sent via WhatsApp)
# In production, set to your domain: https://sorehari.com
BASE_URL=http://localhost:3000