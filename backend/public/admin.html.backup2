<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sorehari Premium Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;1,600&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #F0F2EE;
        }

        .serif-title {
            font-family: 'Playfair Display', serif;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        /* ── Tab Nav Redesign ── */
        .tab-sidebar {
            position: sticky;
            top: 80px;
            height: calc(100vh - 100px);
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: #cbd5e1 transparent;
        }

        .tab-sidebar::-webkit-scrollbar {
            width: 4px;
        }

        .tab-sidebar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

        .nav-tab-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.02em;
            color: #64748b;
            transition: all 0.18s ease;
            text-align: left;
            background: transparent;
            border: none;
            cursor: pointer;
            position: relative;
        }

        .nav-tab-btn:hover {
            background: #fff;
            color: #0f172a;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
        }

        .nav-tab-btn.active {
            background: #0f172a;
            color: #fff;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.18);
        }

        .nav-tab-btn .tab-icon {
            font-size: 16px;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .nav-tab-group-label {
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 0.12em;
            color: #94a3b8;
            text-transform: uppercase;
            padding: 16px 14px 4px;
        }

        .nav-tab-divider {
            height: 1px;
            background: #e2e8f0;
            margin: 8px 0;
        }

        /* ── Dashboard Cards ── */
        .dash-card {
            background: #fff;
            border-radius: 20px;
            border: 1px solid rgba(226, 232, 240, 0.8);
            padding: 24px;
            transition: box-shadow 0.2s;
        }

        .dash-card:hover {
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
        }

        .dash-kpi-value {
            font-size: 28px;
            font-weight: 800;
            color: #0f172a;
            line-height: 1.1;
        }

        .dash-kpi-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: #94a3b8;
            margin-top: 4px;
        }

        .dash-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 8px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 700;
        }

        .dash-activity-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid #f1f5f9;
        }

        .dash-activity-row:last-child {
            border-bottom: none;
        }

        /* ── Sidebar Layout ── */
        .admin-layout {
            display: grid;
            grid-template-columns: 220px 1fr;
            gap: 24px;
            align-items: start;
        }

        @media (max-width: 900px) {
            .admin-layout {
                grid-template-columns: 1fr;
            }

            .tab-sidebar {
                position: static;
                height: auto;
                display: flex;
                flex-wrap: wrap;
                gap: 4px;
            }

            .nav-tab-group-label,
            .nav-tab-divider {
                display: none;
            }

            .nav-tab-btn {
                width: auto;
                padding: 8px 12px;
                font-size: 10px;
            }
        }

        @media print {
            body {
                background: white !important;
                color: black !important;
            }

            header,
            .flex-grow,
            footer,
            .no-print,
            #invoice-modal,
            #walog-modal,
            #freelancer-modal,
            #disb-pay-modal,
            #disb-receipt-modal,
            #disb-add-modal,
            #booking-crew-modal,
            #cancel-booking-modal {
                display: none !important;
            }

            #client-invoice-modal {
                display: block !important;
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                height: auto;
                background: white !important;
                box-shadow: none !important;
                z-index: 9999 !important;
            }

            #client-invoice-printable {
                display: block !important;
                visibility: visible !important;
            }

            #client-invoice-printable * {
                visibility: visible !important;
            }
        }
    </style>
</head>

<body class="min-h-screen text-slate-800 flex flex-col justify-between">
    <!-- Header -->
    <header class="sticky top-0 z-30 border-b border-slate-200 bg-white/90 backdrop-blur shadow-sm">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
            <div class="flex items-center gap-3">
                <span
                    class="h-8 w-8 rounded-full bg-slate-900 flex items-center justify-center text-white font-bold text-sm">S</span>
                <h1 class="serif-title text-xl font-bold text-slate-900">Sorehari Admin</h1>
            </div>
            <div class="flex items-center gap-4">
                <a href="/"
                    class="text-xs font-semibold text-slate-500 hover:text-slate-900 transition flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Lihat Website
                </a>
                <button onclick="openAdminLogin()"
                    class="rounded-xl bg-purple-50 hover:bg-purple-100 text-purple-600 px-4 py-2 text-xs font-bold transition flex items-center gap-1.5"
                    title="Login Admin">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z">
                        </path>
                    </svg>
                    Login Admin
                </button>
                <button onclick="handleLogout()"
                    class="rounded-xl bg-red-50 hover:bg-red-100 text-red-600 px-4 py-2 text-xs font-bold transition">
                    Keluar (Logout)
                </button>
            </div>
        </div>
    </header>

    <!-- Main Workspace -->
    <div class="flex-grow mx-auto max-w-7xl w-full px-6 py-8">
        <div class="admin-layout">

            <!-- ── SIDEBAR NAVIGATION ── -->
            <aside class="tab-sidebar">
                <nav class="bg-white rounded-2xl border border-slate-200 p-2 shadow-sm">

                    <!-- Branding strip -->
                    <div class="px-3 py-3 mb-1 border-b border-slate-100">
                        <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Sorehari Studio</p>
                        <p class="text-[11px] font-bold text-slate-700 mt-0.5">Admin Panel</p>
                    </div>

                    <!-- Overview -->
                    <div class="nav-tab-group-label">Overview</div>
                    <button onclick="switchTab('tab-dashboard')" id="btn-tab-dashboard" class="nav-tab-btn active">
                        <span class="tab-icon">📊</span> Dashboard
                    </button>

                    <!-- Operasional -->
                    <div class="nav-tab-divider"></div>
                    <div class="nav-tab-group-label">Operasional</div>
                    <button onclick="switchTab('tab-bookings')" id="btn-tab-bookings" class="nav-tab-btn">
                        <span class="tab-icon">👥</span> Client Status
                    </button>
                    <button onclick="switchTab('tab-packages')" id="btn-tab-packages" class="nav-tab-btn">
                        <span class="tab-icon">📦</span> Paket Layanan
                    </button>
                    <button onclick="switchTab('tab-freelancers')" id="btn-tab-freelancers" class="nav-tab-btn">
                        <span class="tab-icon">🎬</span> Kru Freelance
                    </button>

                    <!-- Keuangan -->
                    <div class="nav-tab-divider"></div>
                    <div class="nav-tab-group-label">Keuangan</div>
                    <button onclick="switchTab('tab-payment');" id="btn-tab-payment" class="nav-tab-btn">
                        <span class="tab-icon">💳</span> Pembayaran
                    </button>
                    <button onclick="switchTab('tab-disbursement');" id="btn-tab-disbursement" class="nav-tab-btn">
                        <span class="tab-icon">💸</span> Gaji Freelance
                    </button>
                    <button onclick="switchTab('tab-pricing');" id="btn-tab-pricing" class="nav-tab-btn">
                        <span class="tab-icon">🏷️</span> Master Pricing
                    </button>
                    <button onclick="switchTab('tab-financial'); loadFinancialReport();" id="btn-tab-financial"
                        class="nav-tab-btn">
                        <span class="tab-icon">📈</span> Lap. Keuangan
                    </button>

                    <!-- Lainnya -->
                    <div class="nav-tab-divider"></div>
                    <div class="nav-tab-group-label">Lainnya</div>
                    <button onclick="switchTab('tab-audit');" id="btn-tab-audit" class="nav-tab-btn">
                        <span class="tab-icon">📋</span> Audit Log
                    </button>
                    <button onclick="switchTab('tab-portfolio')" id="btn-tab-portfolio" class="nav-tab-btn">
                        <span class="tab-icon">📸</span> Portofolio
                    </button>
                    <button onclick="switchTab('tab-settings')" id="btn-tab-settings" class="nav-tab-btn">
                        <span class="tab-icon">⚙️</span> Pengaturan
                    </button>

                </nav>
            </aside>

            <!-- ── MAIN CONTENT AREA ── -->
            <main>


                <!-- TAB CONTENT: DASHBOARD -->
                <section id="tab-dashboard" class="tab-content space-y-6">
                    <!-- Header -->
                    <div>
                        <h2 class="serif-title text-2xl font-bold text-slate-900">Dashboard</h2>
                        <p class="text-xs text-slate-500 mt-1">Ringkasan bisnis Sorehari Studio secara real-time.</p>
                    </div>

                    <!-- KPI Cards Row -->
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div class="dash-card">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-2xl">👥</span>
                                <span class="dash-badge bg-blue-50 text-blue-600" id="dash-badge-running">0 aktif</span>
                            </div>
                            <div class="dash-kpi-value" id="dash-kpi-total-clients">-</div>
                            <div class="dash-kpi-label">Total Client</div>
                        </div>
                        <div class="dash-card">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-2xl">💰</span>
                                <span class="dash-badge bg-emerald-50 text-emerald-600">Tahun Ini</span>
                            </div>
                            <div class="dash-kpi-value text-emerald-700" id="dash-kpi-revenue" style="font-size:20px">-
                            </div>
                            <div class="dash-kpi-label">Total Revenue</div>
                        </div>
                        <div class="dash-card">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-2xl">✅</span>
                                <span class="dash-badge bg-purple-50 text-purple-600" id="dash-badge-done">0
                                    selesai</span>
                            </div>
                            <div class="dash-kpi-value" id="dash-kpi-lunas">-</div>
                            <div class="dash-kpi-label">Klien Lunas</div>
                        </div>
                        <div class="dash-card">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-2xl">🎬</span>
                                <span class="dash-badge bg-amber-50 text-amber-600" id="dash-badge-crew">0 aktif</span>
                            </div>
                            <div class="dash-kpi-value" id="dash-kpi-freelancers">-</div>
                            <div class="dash-kpi-label">Kru Freelance</div>
                        </div>
                    </div>

                    <!-- Charts Row -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Recent Activity / Upcoming Events -->
                        <div class="dash-card">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-sm font-bold text-slate-800">📅 Jadwal Wedding Terdekat</h3>
                                <button onclick="switchTab('tab-bookings')"
                                    class="text-[10px] font-bold text-indigo-600 hover:text-indigo-800 transition">Lihat
                                    Semua →</button>
                            </div>
                            <div id="dash-upcoming-list" class="space-y-0">
                                <div class="dash-activity-row">
                                    <div class="h-8 w-8 rounded-xl bg-slate-100 animate-pulse"></div>
                                    <div class="flex-1 space-y-1.5">
                                        <div class="h-3 bg-slate-100 rounded animate-pulse w-3/4"></div>
                                        <div class="h-2.5 bg-slate-100 rounded animate-pulse w-1/2"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Payment Status Breakdown -->
                        <div class="dash-card">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-sm font-bold text-slate-800">💳 Status Pembayaran</h3>
                            </div>
                            <div id="dash-payment-breakdown" class="space-y-3">
                                <!-- Filled by JS -->
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Row: Project Status + Financial Snapshot -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Project Pipeline -->
                        <div class="dash-card">
                            <h3 class="text-sm font-bold text-slate-800 mb-4">🔄 Pipeline Proyek</h3>
                            <div id="dash-pipeline" class="space-y-2.5">
                                <!-- Filled by JS -->
                            </div>
                        </div>

                        <!-- Financial Snapshot -->
                        <div class="dash-card"
                            style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-color: transparent;">
                            <h3 class="text-sm font-bold text-white mb-4">📊 Snapshot Keuangan</h3>
                            <div class="space-y-3" id="dash-finance-snapshot">
                                <div class="flex justify-between items-center">
                                    <span class="text-xs text-slate-400">Total Revenue (Tahun Ini)</span>
                                    <span class="text-xs font-bold text-emerald-400" id="dash-fin-revenue">-</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-xs text-slate-400">Total Pengeluaran</span>
                                    <span class="text-xs font-bold text-red-400" id="dash-fin-expenses">-</span>
                                </div>
                                <div class="h-px bg-white/10 my-1"></div>
                                <div class="flex justify-between items-center">
                                    <span class="text-xs text-white font-bold">Net Profit</span>
                                    <span class="text-sm font-black text-white" id="dash-fin-profit">-</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-xs text-slate-400">Total Booking</span>
                                    <span class="text-xs font-bold text-amber-400" id="dash-fin-bookings">-</span>
                                </div>
                            </div>
                            <div class="mt-4 pt-4 border-t border-white/10">
                                <button onclick="switchTab('tab-financial'); loadFinancialReport();"
                                    class="w-full py-2.5 rounded-xl text-xs font-bold text-slate-900 bg-white/90 hover:bg-white transition">Lihat
                                    Laporan Keuangan →</button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- TAB CONTENT: BOOKINGS & OPERATIONS -->
                <section id="tab-bookings" class="tab-content hidden space-y-6">
                    <!-- Header Ops -->
                    <div class="flex flex-col items-center justify-center text-center gap-4">
                        <div>
                            <h2 class="serif-title text-2xl font-bold text-slate-900">Client Status</h2>
                            <p class="text-xs text-slate-500 mt-1">Kendalikan status keuangan, operasional, dan alokasi
                                kru wedding
                                otomatis.</p>
                        </div>
                        <!-- WhatsApp Log Trigger Toggle -->
                        <button onclick="toggleWaLogModal()"
                            class="rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-xs font-bold text-slate-700 hover:bg-slate-50 flex items-center gap-2 shadow-sm transition">
                            💬 WhatsApp Outbox Simulation
                        </button>
                    </div>

                    <!-- Sub Tabs for Client Status -->
                    <div class="flex justify-center">
                        <div class="flex gap-2 mb-2 bg-slate-100 p-1.5 rounded-xl max-w-md w-full">
                            <button onclick="setClientStatusTab('running')" id="subtab-running"
                                class="flex-1 px-4 py-2.5 rounded-lg text-xs font-bold transition bg-white shadow-sm text-slate-900">Sedang
                                Berjalan</button>
                            <button onclick="setClientStatusTab('selesai')" id="subtab-selesai"
                                class="flex-1 px-4 py-2.5 rounded-lg text-xs font-bold transition hover:bg-white/50 text-slate-500">Selesai</button>
                            <button onclick="setClientStatusTab('batal')" id="subtab-batal"
                                class="flex-1 px-4 py-2.5 rounded-lg text-xs font-bold transition hover:bg-white/50 text-slate-500">Batal</button>
                        </div>
                    </div>

                    <!-- Booking Cards/Table Grid -->
                    <div class="bg-white rounded-3xl border border-slate-200/80 shadow-sm overflow-hidden">
                        <div
                            class="p-6 border-b border-slate-200 flex flex-col items-center justify-center gap-4 bg-slate-50/50">
                            <div class="flex justify-between items-center w-full">
                                <span class="text-xs font-bold uppercase tracking-wider text-slate-500"
                                    id="booking-count-lbl">Daftar Transaksi (0)</span>
                            </div>

                            <!-- Hidden inputs & selects to keep current JS logic intact -->
                            <input type="hidden" id="filter-payment" value="">
                            <select id="filter-project" onchange="loadBookings()"
                                class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs focus:outline-none bg-white hidden">
                                <option value="">Semua Proyek</option>
                                <option value="Pending">Pending</option>
                                <option value="On Progress">On Progress</option>
                                <option value="Post-Prod: Editing">Post-Prod: Editing</option>
                                <option value="Post-Prod: Review">Post-Prod: Review</option>
                                <option value="Post-Prod: Cetak Album">Post-Prod: Cetak Album</option>
                                <option value="Selesai">Selesai</option>
                            </select>

                            <!-- Centered Financial Filter Tabs -->
                            <div id="financial-filter-container"
                                class="flex flex-wrap justify-center gap-1.5 p-1 bg-slate-100 rounded-xl border border-slate-200 max-w-2xl w-full">
                                <button type="button" onclick="setPaymentFilter('', this)"
                                    class="payment-filter-btn flex-1 min-w-[90px] px-3 py-2 rounded-lg text-[10px] sm:text-xs font-bold transition bg-white shadow-sm text-slate-900">Daftar
                                    Client</button>
                                <button type="button" onclick="setPaymentFilter('Menunggu DP', this)"
                                    class="payment-filter-btn flex-1 min-w-[90px] px-3 py-2 rounded-lg text-[10px] sm:text-xs font-bold transition text-slate-500 hover:bg-white/50">Menunggu
                                    DP</button>
                                <button type="button" onclick="setPaymentFilter('Menunggu Pelunasan', this)"
                                    class="payment-filter-btn flex-1 min-w-[90px] px-3 py-2 rounded-lg text-[10px] sm:text-xs font-bold transition text-slate-500 hover:bg-white/50">Menunggu
                                    Lunas</button>
                                <button type="button" onclick="setPaymentFilter('Lunas', this)"
                                    class="payment-filter-btn flex-1 min-w-[90px] px-3 py-2 rounded-lg text-[10px] sm:text-xs font-bold transition text-slate-500 hover:bg-white/50">Lunas</button>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr
                                        class="bg-slate-100/50 text-[10px] uppercase font-bold tracking-wider text-slate-500 border-b border-slate-200">
                                        <th class="p-4">Klien & Tanggal</th>
                                        <th class="p-4">Paket & Harga Deal</th>
                                        <th class="p-4">Status Keuangan</th>
                                        <th class="p-4">Alokasi Kru</th>
                                        <th class="p-4">Status Proyek</th>
                                        <th class="p-4 text-right">Aksi Operasional</th>
                                    </tr>
                                </thead>
                                <tbody id="bookings-table-body" class="divide-y divide-slate-100 text-xs">
                                    <tr>
                                        <td colspan="6" class="p-8 text-center text-slate-500">Memuat data transaksi...
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>

                <!-- TAB CONTENT: PORTFOLIO & PHOTO UPLOADS (Fitur Lama yang Dipertahankan) -->
                <section id="tab-portfolio" class="tab-content hidden space-y-6">
                    <!-- Form Baru Tambah Portofolio -->
                    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                        <h2 class="serif-title text-xl font-semibold text-slate-900 mb-4">Buat Halaman Portofolio Baru
                        </h2>
                        <form id="add-client-form" class="space-y-4" onsubmit="createNewPortfolio(event)">
                            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                                <div>
                                    <label
                                        class="block text-xs font-semibold text-slate-600 uppercase tracking-wider">Nama
                                        Client</label>
                                    <input type="text" id="client-name" required placeholder="Contoh: Budi & Rina"
                                        class="mt-2 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-xs bg-slate-50 focus:border-slate-900 focus:outline-none focus:ring-1 focus:ring-slate-900 transition">
                                </div>
                                <div>
                                    <label
                                        class="block text-xs font-semibold text-slate-600 uppercase tracking-wider">Lokasi
                                        Acara</label>
                                    <input type="text" id="client-location" placeholder="Contoh: Hotel Mulia, Jakarta"
                                        class="mt-2 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-xs bg-slate-50 focus:border-slate-900 focus:outline-none focus:ring-1 focus:ring-slate-900 transition">
                                </div>
                                <div>
                                    <label
                                        class="block text-xs font-semibold text-slate-600 uppercase tracking-wider">Tanggal
                                        Acara</label>
                                    <input type="date" id="client-date"
                                        class="mt-2 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-xs bg-slate-50 focus:border-slate-900 focus:outline-none focus:ring-1 focus:ring-slate-900 transition">
                                </div>
                                <div>
                                    <label
                                        class="block text-xs font-semibold text-slate-600 uppercase tracking-wider">Deskripsi/Kutipan
                                        Portofolio</label>
                                    <input type="text" id="client-description"
                                        placeholder="Contoh: Momen indah yang tak terlupakan"
                                        class="mt-2 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-xs bg-slate-50 focus:border-slate-900 focus:outline-none focus:ring-1 focus:ring-slate-900 transition">
                                </div>
                                <div>
                                    <label
                                        class="block text-xs font-semibold text-slate-600 uppercase tracking-wider">Hubungkan
                                        Dengan Booking Klien (Opsional)</label>
                                    <select id="client-booking-id"
                                        class="mt-2 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-xs bg-slate-50 focus:border-slate-900 focus:outline-none focus:ring-1 focus:ring-slate-900 transition">
                                        <option value="">Pilih Booking Klien</option>
                                    </select>
                                </div>
                            </div>
                            <button type="submit"
                                class="rounded-xl bg-slate-900 px-6 py-2.5 text-xs font-bold text-white hover:bg-slate-800 transition">
                                + Buat Portofolio Klien
                            </button>
                        </form>
                    </div>

                    <!-- List Portofolio & Upload Foto (Fitur Lama) -->
                    <div>
                        <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Unggah & Urutan Foto
                            Portofolio</h3>
                        <div id="clients-container" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                            <!-- Loaded dynamically -->
                        </div>
                    </div>
                </section>

                <!-- TAB CONTENT: FREELANCERS DATABASE -->
                <section id="tab-freelancers" class="tab-content hidden space-y-6">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <div>
                            <h2 class="serif-title text-2xl font-bold text-slate-900">Database Kru Lapangan (Freelancer)
                            </h2>
                            <p class="text-xs text-slate-500">Mendaftarkan kru fotografer dan videografer lepas untuk
                                antrean
                                jadwal otomatis.</p>
                        </div>
                        <button onclick="openFreelancerModal()"
                            class="rounded-xl bg-slate-900 hover:bg-slate-800 text-white px-4 py-2.5 text-xs font-bold transition shadow-sm">
                            + Tambah Kru Baru
                        </button>
                    </div>

                    <div class="bg-white rounded-3xl border border-slate-200/80 shadow-sm overflow-hidden">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr
                                    class="bg-slate-100/50 text-[10px] uppercase font-bold tracking-wider text-slate-500 border-b border-slate-200">
                                    <th class="p-4">Nama Kru</th>
                                    <th class="p-4">Spesialisasi / Peran</th>
                                    <th class="p-4">Nomor WhatsApp</th>
                                    <th class="p-4">Fee Per Proyek</th>
                                    <th class="p-4">Status Operasional</th>
                                    <th class="p-4 text-right">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="freelancers-table-body" class="divide-y divide-slate-100 text-xs">
                                <!-- Loaded dynamically -->
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- TAB CONTENT: PACKAGES SETTINGS -->
                <section id="tab-packages" class="tab-content hidden space-y-6">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <div>
                            <h2 class="serif-title text-2xl font-bold text-slate-900">Paket Layanan</h2>
                            <p class="text-xs text-slate-500">Susun paket layanan untuk ditawarkan kepada klien saat
                                booking. Setiap paket bisa diisi dengan layanan dari daftar Biaya Modal & Jasa.</p>
                        </div>
                        <button onclick="openPackageModal()"
                            class="rounded-xl bg-slate-900 hover:bg-slate-800 text-white px-4 py-2.5 text-xs font-bold transition shadow-sm">
                            + Buat Paket Baru
                        </button>
                    </div>

                    <div class="bg-white rounded-3xl border border-slate-200/80 shadow-sm overflow-hidden">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr
                                    class="bg-slate-100/50 text-[10px] uppercase font-bold tracking-wider text-slate-500 border-b border-slate-200">
                                    <th class="p-4">Nama Paket</th>
                                    <th class="p-4">Harga Jual</th>
                                    <th class="p-4">Estimasi Modal</th>
                                    <th class="p-4">Kru (FG / VG)</th>
                                    <th class="p-4">Isi Layanan</th>
                                    <th class="p-4 text-right">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="packages-table-body" class="divide-y divide-slate-100 text-xs">
                                <!-- Loaded dynamically -->
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- TAB CONTENT: FINANCIAL REPORTS -->
                <section id="tab-financial" class="tab-content hidden space-y-6">
                    <!-- Header -->
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                        <div>
                            <h2 class="serif-title text-2xl font-bold text-slate-900">Laporan Keuangan</h2>
                            <p class="text-xs text-slate-500 mt-1">Laporan berbasis <strong>kas masuk aktual</strong> —
                                hanya uang yang sudah diterima yang dihitung sebagai pendapatan.</p>
                        </div>
                        <span id="fin-period-closed-badge"
                            class="hidden px-3 py-1.5 rounded-xl text-xs font-bold bg-amber-100 text-amber-700 border border-amber-200 self-start">🔒
                            Periode Dikunci</span>
                    </div>

                    <!-- Period Filter Bar -->
                    <div class="bg-white rounded-2xl border border-slate-200 p-4 shadow-sm">
                        <div class="flex flex-wrap items-end justify-between gap-3">
                            <div class="flex flex-wrap items-end gap-3">
                                <div>
                                    <label
                                        class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-1">Jenis
                                        Periode</label>
                                    <select id="fin-report-type" onchange="toggleFinMonth()"
                                        class="rounded-lg border border-slate-200 px-3 py-2 bg-white text-xs font-semibold focus:outline-none">
                                        <option value="monthly">📅 Bulanan</option>
                                        <option value="yearly">📆 Tahunan</option>
                                    </select>
                                </div>
                                <div id="fin-month-wrap">
                                    <label
                                        class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-1">Bulan</label>
                                    <select id="fin-report-month"
                                        class="rounded-lg border border-slate-200 px-3 py-2 bg-white text-xs font-semibold focus:outline-none">
                                        <option value="1">Januari</option>
                                        <option value="2">Februari</option>
                                        <option value="3">Maret</option>
                                        <option value="4">April</option>
                                        <option value="5">Mei</option>
                                        <option value="6">Juni</option>
                                        <option value="7">Juli</option>
                                        <option value="8">Agustus</option>
                                        <option value="9">September</option>
                                        <option value="10">Oktober</option>
                                        <option value="11">November</option>
                                        <option value="12">Desember</option>
                                    </select>
                                </div>
                                <div>
                                    <label
                                        class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-1">Tahun</label>
                                    <select id="fin-report-year"
                                        class="rounded-lg border border-slate-200 px-3 py-2 bg-white text-xs font-semibold focus:outline-none"></select>
                                </div>
                                <button onclick="loadFinancialReport()"
                                    class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-lg hover:bg-slate-800 transition">Tampilkan</button>
                            </div>
                            <div class="flex items-end gap-2">
                                <button onclick="exportFinancialReport()"
                                    class="px-3 py-2 bg-emerald-600 text-white text-xs font-bold rounded-lg hover:bg-emerald-700 transition flex items-center gap-1.5">📥
                                    Export CSV</button>
                                <button onclick="openClosePeriodModal()"
                                    class="px-3 py-2 bg-amber-500 text-white text-xs font-bold rounded-lg hover:bg-amber-600 transition flex items-center gap-1.5">🔒
                                    Tutup Buku</button>
                            </div>
                        </div>
                        <!-- Period Label -->
                        <div class="mt-3 pt-3 border-t border-slate-100 flex items-center gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Periode:</span>
                            <span id="fin-period-label" class="text-xs font-bold text-slate-700">—</span>
                            <span class="text-[10px] text-slate-400" id="fin-period-dates"></span>
                        </div>
                    </div>

                    <!-- KPI Cards — 5 cards -->
                    <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-3">
                        <!-- Kas Masuk -->
                        <div class="bg-white rounded-2xl border border-slate-200 p-4 shadow-sm">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">💵 Kas Masuk</p>
                            <p class="text-[9px] text-slate-400 mt-0.5">DP + Pelunasan diterima</p>
                            <h4 class="serif-title text-lg font-extrabold text-slate-900 mt-2" id="fin-total-revenue">Rp
                                0</h4>
                            <div class="flex gap-2 mt-2">
                                <span class="text-[10px] text-slate-500">DP: <span class="font-bold text-slate-700"
                                        id="fin-kas-dp">Rp 0</span></span>
                                <span class="text-[10px] text-slate-400">|</span>
                                <span class="text-[10px] text-slate-500">Lunas: <span class="font-bold text-slate-700"
                                        id="fin-kas-final">Rp 0</span></span>
                            </div>
                        </div>
                        <!-- Piutang -->
                        <div class="bg-white rounded-2xl border border-amber-200 p-4 shadow-sm">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-amber-500">⏳ Piutang</p>
                            <p class="text-[9px] text-slate-400 mt-0.5">Belum dibayar klien</p>
                            <h4 class="serif-title text-lg font-extrabold text-amber-600 mt-2" id="fin-piutang">Rp 0
                            </h4>
                            <p class="text-[10px] text-slate-400 mt-2">Nilai kontrak: <span class="font-bold"
                                    id="fin-nilai-kontrak">Rp 0</span></p>
                        </div>
                        <!-- Pengeluaran -->
                        <div class="bg-white rounded-2xl border border-red-200 p-4 shadow-sm">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-red-500">📤 Pengeluaran</p>
                            <p class="text-[9px] text-slate-400 mt-0.5">Total biaya operasional</p>
                            <h4 class="serif-title text-lg font-extrabold text-red-600 mt-2" id="fin-total-expenses">Rp
                                0</h4>
                            <p class="text-[10px] text-slate-400 mt-2">Diskon diberikan: <span class="font-bold"
                                    id="fin-total-diskon">Rp 0</span></p>
                        </div>
                        <!-- Laba Bersih -->
                        <div class="bg-slate-950 rounded-2xl p-4 shadow-md">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">📈 Laba Bersih</p>
                            <p class="text-[9px] text-slate-500 mt-0.5">Kas masuk − pengeluaran</p>
                            <h4 class="serif-title text-lg font-extrabold text-emerald-400 mt-2" id="fin-net-profit">Rp
                                0</h4>
                            <p class="text-[10px] text-slate-500 mt-2">Proyeksi: <span class="font-bold text-slate-300"
                                    id="fin-laba-proyeksi">Rp 0</span></p>
                        </div>
                        <!-- Saldo Modal -->
                        <div class="bg-white rounded-2xl border border-indigo-200 p-4 shadow-sm">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-indigo-500">🏦 Saldo Modal</p>
                            <p class="text-[9px] text-slate-400 mt-0.5">Laba − penarikan</p>
                            <h4 class="serif-title text-lg font-extrabold text-indigo-700 mt-2"
                                id="fin-capital-balance">Rp 0</h4>
                            <p class="text-[10px] text-slate-400 mt-2">Min: <span id="fin-minimum-capital"
                                    class="font-bold">Rp 0</span></p>
                        </div>
                    </div>

                    <!-- Main Content: Expense Breakdown + Withdrawals -->
                    <div class="grid gap-4 md:grid-cols-2">
                        <!-- Expense Breakdown -->
                        <div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm">
                            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">📤 Rincian
                                Pengeluaran</h3>
                            <div class="space-y-2.5 text-xs">
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-600">Post Produksi (Edit)</span>
                                    <span class="font-bold text-slate-800" id="fin-exp-postprod">Rp 0</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-600">Cetak Album</span>
                                    <span class="font-bold text-slate-800" id="fin-exp-album">Rp 0</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-600">Frame / Pigura</span>
                                    <span class="font-bold text-slate-800" id="fin-exp-frame">Rp 0</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-600">Logistik & Transport</span>
                                    <span class="font-bold text-slate-800" id="fin-exp-logistics">Rp 0</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-600">Fee Kru Freelance</span>
                                    <span class="font-bold text-slate-800" id="fin-exp-staff">Rp 0</span>
                                </div>
                                <div class="border-t pt-2.5 flex justify-between font-bold text-sm">
                                    <span class="text-slate-800">Total Pengeluaran</span>
                                    <span class="text-red-600" id="fin-exp-total">Rp 0</span>
                                </div>
                            </div>
                        </div>

                        <!-- Withdrawals -->
                        <div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm">
                            <div class="flex justify-between items-center mb-4">
                                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">💸 Penarikan Dana
                                </h3>
                                <button onclick="openWithdrawalModal()"
                                    class="px-3 py-1.5 bg-indigo-600 text-white text-[10px] font-bold rounded-lg hover:bg-indigo-700 transition">+
                                    Tarik Dana</button>
                            </div>
                            <div id="withdrawals-list" class="space-y-2 max-h-44 overflow-y-auto text-xs mb-3">
                                <p class="text-slate-400 text-center py-4">Belum ada penarikan</p>
                            </div>
                            <div class="border-t pt-3 space-y-2 text-xs">
                                <div class="flex justify-between"><span class="text-slate-600">Total Ditarik</span><span
                                        class="font-bold text-orange-600" id="fin-total-withdrawals">Rp 0</span></div>
                                <div class="flex justify-between"><span class="font-bold text-slate-800">Tersedia
                                        Ditarik</span><span class="font-bold text-emerald-600 text-sm"
                                        id="fin-available-withdrawal">Rp 0</span></div>
                            </div>
                        </div>
                    </div>

                    <!-- Financial Settings -->
                    <div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm">
                        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">⚙️ Pengaturan
                            Keuangan</h3>
                        <div class="grid gap-4 md:grid-cols-3">
                            <div>
                                <label
                                    class="text-[10px] font-bold uppercase tracking-widest text-slate-500 block mb-1">Modal
                                    Minimum (Rp)</label>
                                <input type="number" id="fin-min-capital-input"
                                    class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs bg-slate-50 focus:outline-none"
                                    placeholder="0">
                                <p class="text-[10px] text-slate-400 mt-1">Saldo yang tidak bisa ditarik sebagai
                                    cadangan modal</p>
                            </div>
                            <div>
                                <label
                                    class="text-[10px] font-bold uppercase tracking-widest text-slate-500 block mb-1">Nama
                                    Usaha</label>
                                <input type="text" id="fin-business-name"
                                    class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs bg-slate-50 focus:outline-none"
                                    placeholder="Sorehari Photography">
                            </div>
                            <div>
                                <label
                                    class="text-[10px] font-bold uppercase tracking-widest text-slate-500 block mb-1">Rekening
                                    Bank</label>
                                <input type="text" id="fin-bank-account"
                                    class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs bg-slate-50 focus:outline-none"
                                    placeholder="BANK - No.Rek a.n. Nama">
                            </div>
                        </div>
                        <button onclick="saveFinancialSettings()"
                            class="mt-4 px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-lg hover:bg-slate-700 transition">Simpan
                            Pengaturan</button>
                    </div>

                    <!-- Per-Project Detail Table -->
                    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="p-4 border-b border-slate-100 flex items-center justify-between">
                            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">📋 Rincian Per Proyek
                            </h3>
                            <span class="text-[10px] text-slate-400" id="fin-table-count"></span>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-xs">
                                <thead>
                                    <tr
                                        class="bg-slate-50 text-[10px] font-bold uppercase tracking-wider text-slate-500 border-b border-slate-200">
                                        <th class="p-3">Klien / Tgl Event</th>
                                        <th class="p-3">Paket</th>
                                        <th class="p-3 text-right">Nilai Kontrak</th>
                                        <th class="p-3 text-right">DP Masuk</th>
                                        <th class="p-3 text-right">Pelunasan</th>
                                        <th class="p-3 text-right">Kas Masuk</th>
                                        <th class="p-3 text-right">Pengeluaran</th>
                                        <th class="p-3 text-right">Laba</th>
                                        <th class="p-3 text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody id="fin-table-body" class="divide-y divide-slate-100">
                                    <tr>
                                        <td colspan="9" class="p-6 text-center text-slate-400">Pilih periode lalu klik
                                            Tampilkan</td>
                                    </tr>
                                </tbody>
                                <tfoot id="fin-table-footer" class="hidden">
                                    <tr class="bg-slate-50 font-bold text-xs border-t-2 border-slate-200">
                                        <td class="p-3" colspan="2">TOTAL</td>
                                        <td class="p-3 text-right text-slate-700" id="fin-foot-kontrak">-</td>
                                        <td class="p-3 text-right text-slate-700" id="fin-foot-dp">-</td>
                                        <td class="p-3 text-right text-slate-700" id="fin-foot-final">-</td>
                                        <td class="p-3 text-right text-emerald-700" id="fin-foot-kas">-</td>
                                        <td class="p-3 text-right text-red-600" id="fin-foot-exp">-</td>
                                        <td class="p-3 text-right text-emerald-700" id="fin-foot-laba">-</td>
                                        <td class="p-3"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </section>


                <!-- TAB CONTENT: DISBURSEMENT (Gaji & Fee Freelancer) -->
                <section id="tab-disbursement" class="tab-content hidden space-y-6">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <div>
                            <h2 class="serif-title text-2xl font-bold text-slate-900">Gaji Freelancer</h2>
                            <p class="text-xs text-slate-500 mt-1">Kelola pembayaran fee kru freelance untuk setiap
                                project yang sudah selesai.</p>
                        </div>
                        <button onclick="openAddDisbursementModal()"
                            class="rounded-xl bg-slate-900 hover:bg-slate-800 text-white px-4 py-2.5 text-xs font-bold transition shadow-sm">
                            + Tambah Tagihan Fee
                        </button>
                    </div>

                    <!-- Summary Cards -->
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        <div class="bg-white rounded-3xl border border-slate-200/80 p-5 shadow-sm">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Total Tagihan</p>
                            <h4 class="serif-title text-xl font-extrabold text-slate-900 mt-1" id="disb-total-count">0
                            </h4>
                            <p class="text-[10px] text-slate-400 mt-0.5">entri</p>
                        </div>
                        <div class="bg-white rounded-3xl border border-amber-200 p-5 shadow-sm">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-amber-500">Belum Dibayar</p>
                            <h4 class="serif-title text-xl font-extrabold text-amber-600 mt-1" id="disb-pending-count">0
                            </h4>
                            <p class="text-[10px] text-slate-400 mt-0.5" id="disb-total-unpaid">Rp 0</p>
                        </div>
                        <div class="bg-white rounded-3xl border border-emerald-200 p-5 shadow-sm">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-emerald-500">Sudah Dibayar</p>
                            <h4 class="serif-title text-xl font-extrabold text-emerald-600 mt-1" id="disb-paid-count">0
                            </h4>
                            <p class="text-[10px] text-slate-400 mt-0.5" id="disb-total-paid">Rp 0</p>
                        </div>
                        <div class="bg-slate-950 rounded-3xl p-5 shadow-sm">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Sisa Wajib Bayar
                            </p>
                            <h4 class="serif-title text-xl font-extrabold text-red-400 mt-1"
                                id="disb-total-unpaid-amount">Rp 0</h4>
                            <p class="text-[10px] text-slate-500 mt-0.5">belum terbayarkan</p>
                        </div>
                    </div>

                    <!-- Filter bar -->
                    <div class="flex flex-wrap gap-2 items-center">
                        <select id="disb-status-filter" onchange="loadDisbursements()"
                            class="rounded-lg border border-slate-200 px-3 py-2 bg-white text-xs font-medium focus:outline-none">
                            <option value="WajibBayar" selected>Wajib Bayar (Selesai & Pending)</option>
                            <option value="">Semua Status</option>
                            <option value="Pending">Belum Dibayar (Semua Proyek)</option>
                            <option value="Paid">Sudah Dibayar</option>
                        </select>
                        <span class="text-xs text-slate-400 font-semibold" id="disb-count-label"></span>
                    </div>

                    <!-- Table -->
                    <div class="bg-white rounded-3xl border border-slate-200/80 shadow-sm overflow-hidden">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr
                                    class="bg-slate-100/50 text-[10px] uppercase font-bold tracking-wider text-slate-500 border-b border-slate-200">
                                    <th class="p-4">Freelancer</th>
                                    <th class="p-4">Klien / Acara</th>
                                    <th class="p-4">Peran</th>
                                    <th class="p-4">Nominal Fee</th>
                                    <th class="p-4">Status Proyek</th>
                                    <th class="p-4">Status File</th>
                                    <th class="p-4">Status Fee</th>
                                    <th class="p-4 text-right">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="disb-tbody" class="divide-y divide-slate-100 text-xs">
                                <tr>
                                    <td colspan="8" class="p-8 text-center text-slate-400">Memuat data...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- MODAL: ADD DISBURSEMENT -->
                <div id="disb-add-modal"
                    class="hidden fixed inset-0 z-50 bg-slate-900/60 flex items-center justify-center p-4">
                    <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full p-8 space-y-5">
                        <div class="flex justify-between items-center border-b pb-3">
                            <h3 class="serif-title text-lg font-bold text-slate-900">Tambah Tagihan Fee Freelancer</h3>
                            <button onclick="closeAddDisbursementModal()"
                                class="text-slate-400 hover:text-slate-700 text-xl">&times;</button>
                        </div>
                        <form id="disb-add-form" onsubmit="saveDisbursement(event)" class="space-y-4">
                            <div>
                                <label
                                    class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1">Booking
                                    (Pilih Klien)</label>
                                <select id="disb-booking-select" onchange="onDisbBookingChange()" required
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900">
                                    <option value="">-- Pilih Booking --</option>
                                </select>
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1">Freelancer</label>
                                <select id="disb-freelancer-select" required
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900">
                                    <option value="">-- Pilih booking dahulu --</option>
                                </select>
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1">Peran
                                    / Role</label>
                                <input type="text" id="disb-role" placeholder="Contoh: Fotografer Utama"
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900">
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1">Nominal
                                    Fee (Rp)</label>
                                <input type="number" id="disb-fee-amount" required min="0" placeholder="Contoh: 500000"
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900">
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1">Catatan
                                    (opsional)</label>
                                <textarea id="disb-note" rows="2" placeholder="Contoh: Termasuk biaya transport"
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900"></textarea>
                            </div>
                            <div class="flex gap-3 pt-2">
                                <button type="button" onclick="closeAddDisbursementModal()"
                                    class="w-1/2 py-2.5 rounded-xl border border-slate-300 text-xs font-semibold text-slate-600 hover:bg-slate-50">Batal</button>
                                <button type="submit"
                                    class="w-1/2 py-2.5 rounded-xl bg-slate-900 text-white text-xs font-semibold hover:bg-slate-800 transition">Simpan
                                    Tagihan</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- MODAL: PAY FEE + RECEIPT -->
                <div id="disb-pay-modal"
                    class="hidden fixed inset-0 z-50 bg-slate-900/60 flex items-center justify-center p-4">
                    <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full p-8 space-y-5">
                        <div class="flex justify-between items-center border-b pb-3">
                            <h3 class="serif-title text-lg font-bold text-slate-900">Konfirmasi Pembayaran Fee</h3>
                            <button onclick="closeDisbPayModal()"
                                class="text-slate-400 hover:text-slate-700 text-xl">&times;</button>
                        </div>
                        <input type="hidden" id="disb-pay-id">

                        <!-- Detail summary -->
                        <div class="bg-slate-50 rounded-2xl border border-slate-200 p-4 space-y-2 text-xs">
                            <div class="flex justify-between"><span class="text-slate-500">Freelancer</span><span
                                    class="font-bold text-slate-800" id="disb-pay-freelancer">-</span></div>
                            <div class="flex justify-between"><span class="text-slate-500">Peran</span><span
                                    class="font-semibold text-slate-700" id="disb-pay-role">-</span></div>
                            <div class="flex justify-between"><span class="text-slate-500">Klien</span><span
                                    class="font-semibold text-slate-700" id="disb-pay-client">-</span></div>
                            <div class="flex justify-between"><span class="text-slate-500">Tanggal Acara</span><span
                                    class="font-semibold text-slate-700" id="disb-pay-date">-</span></div>
                            <div class="flex justify-between border-t border-slate-200 pt-2 mt-2">
                                <span class="text-slate-500 font-bold">Nominal Fee</span>
                                <span class="font-extrabold text-emerald-600 text-sm" id="disb-pay-amount">Rp 0</span>
                            </div>
                        </div>

                        <div>
                            <label
                                class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1">Catatan
                                Pembayaran</label>
                            <textarea id="disb-pay-note" rows="2" placeholder="Contoh: Transfer BCA, sudah dikonfirmasi"
                                class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900"></textarea>
                        </div>

                        <div class="flex gap-3 pt-2">
                            <button type="button" onclick="closeDisbPayModal()"
                                class="w-1/2 py-2.5 rounded-xl border border-slate-300 text-xs font-semibold text-slate-600 hover:bg-slate-50">Batal</button>
                            <button type="button" onclick="confirmPayFee()"
                                class="w-1/2 py-2.5 rounded-xl bg-emerald-600 text-white text-xs font-semibold hover:bg-emerald-700 transition">✓
                                Bayar Sekarang</button>
                        </div>
                    </div>
                </div>

                <!-- MODAL: RECEIPT -->
                <div id="disb-receipt-modal"
                    class="hidden fixed inset-0 z-50 bg-slate-900/60 flex items-center justify-center p-4">
                    <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full p-8 space-y-4">
                        <div class="flex justify-between items-center">
                            <h3 class="serif-title text-lg font-bold text-slate-900">Struk Pembayaran</h3>
                            <button onclick="closeDisbReceiptModal()"
                                class="text-slate-400 hover:text-slate-700 text-xl">&times;</button>
                        </div>
                        <pre id="disb-receipt-text"
                            class="text-xs bg-slate-50 border border-slate-200 rounded-xl p-4 whitespace-pre-wrap font-mono text-slate-700 overflow-auto max-h-60"></pre>
                        <div class="flex gap-3">
                            <button onclick="printDisbReceipt()"
                                class="w-1/2 py-2.5 rounded-xl border border-slate-300 text-xs font-semibold text-slate-600 hover:bg-slate-50">🖨
                                Print / Salin</button>
                            <button onclick="closeDisbReceiptModal()"
                                class="w-1/2 py-2.5 rounded-xl bg-slate-900 text-white text-xs font-semibold hover:bg-slate-800 transition">Tutup</button>
                        </div>
                    </div>
                </div>
                <section id="tab-settings" class="tab-content hidden space-y-6 max-w-xl">
                    <div>
                        <h2 class="serif-title text-2xl font-bold text-slate-900">Pengaturan Global Vendor</h2>
                        <p class="text-xs text-slate-500">Sesuaikan batasan operasional harian yang akan tercermin di
                            sistem
                            pendaftaran klien.</p>
                    </div>

                    <div class="bg-white rounded-3xl border border-slate-200/80 p-8 shadow-sm space-y-6">
                        <div class="space-y-2">
                            <label for="max-slots-input"
                                class="block text-xs font-bold text-slate-600 uppercase tracking-widest">Batas Kuota
                                Maksimal
                                Acara Per Hari</label>
                            <p class="text-xs text-slate-400">Jika jumlah pesanan aktif pada 1 hari menyentuh angka ini,
                                kalender pendaftaran publik otomatis mengunci tanggal tersebut.</p>
                            <input type="number" id="max-slots-input" required min="1" max="10"
                                class="mt-2 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm focus:border-slate-900 focus:outline-none transition">
                        </div>
                        <button onclick="saveGlobalSettings()"
                            class="w-full py-3 bg-slate-900 hover:bg-slate-800 text-white rounded-xl text-xs font-bold uppercase tracking-wider transition">
                            Simpan Batas Kuota
                        </button>
                    </div>
                </section>


                <!-- TAB CONTENT: MASTER PRICING -->
                <section id="tab-pricing" class="tab-content hidden space-y-6">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <div>
                            <h2 class="serif-title text-2xl font-bold text-slate-900">Master Pricing</h2>
                            <p class="text-xs text-slate-500 mt-1">Daftar biaya modal & jasa yang tersedia untuk disusun
                                ke dalam Paket Layanan, dan kalkulator estimasi harga custom.</p>
                        </div>
                    </div>

                    <!-- Sub-tab nav -->
                    <div class="flex gap-2 bg-slate-100 p-1.5 rounded-2xl max-w-sm">
                        <button id="ptab-btn-services" onclick="switchPricingTab('services')"
                            class="flex-1 px-4 py-2 rounded-xl text-xs font-bold bg-white shadow text-slate-900 transition">💰
                            Biaya Modal & Jasa</button>
                        <button id="ptab-btn-calculator" onclick="switchPricingTab('calculator')"
                            class="flex-1 px-4 py-2 rounded-xl text-xs font-bold text-slate-500 hover:text-slate-900 transition">🧮
                            Kalkulator</button>
                    </div>

                    <!-- Services Panel -->
                    <div id="ptab-services" class="space-y-4">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div>
                                <span class="text-xs font-bold uppercase tracking-widest text-slate-500">Daftar Biaya
                                    Modal & Jasa</span>
                                <p class="text-[10px] text-slate-400 mt-0.5">Ini adalah daftar item/jasa beserta harga
                                    modalnya. Item ini bisa dipilih saat membuat Paket Layanan.</p>
                            </div>
                            <div class="flex flex-wrap items-center gap-3">
                                <!-- Category Sub-Tabs -->
                                <div class="flex gap-1 bg-slate-100 p-1 rounded-xl">
                                    <button id="service-cat-all" onclick="filterServiceCategory('all')"
                                        class="px-3.5 py-1.5 rounded-xl text-xs font-bold bg-white shadow-sm text-slate-900 transition">Semua</button>
                                    <button id="service-cat-fisik" onclick="filterServiceCategory('Output Fisik')"
                                        class="px-3.5 py-1.5 rounded-xl text-xs font-bold text-slate-500 hover:text-slate-900 transition">Output Fisik</button>
                                    <button id="service-cat-digital" onclick="filterServiceCategory('Output Digital')"
                                        class="px-3.5 py-1.5 rounded-xl text-xs font-bold text-slate-500 hover:text-slate-900 transition">Output Digital</button>
                                </div>
                                <button onclick="openAddServiceModal()"
                                    class="rounded-xl bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-xs font-bold transition shadow-sm whitespace-nowrap">+
                                    Tambah Item</button>
                            </div>
                        </div>
                        <div class="bg-white rounded-3xl border border-slate-200/80 shadow-sm overflow-hidden">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr
                                        class="bg-slate-100/50 text-[10px] uppercase font-bold tracking-wider text-slate-500 border-b border-slate-200">
                                        <th class="p-4">Nama Item / Jasa</th>
                                        <th class="p-4">Kategori</th>
                                        <th class="p-4">Harga Modal / Unit</th>
                                        <th class="p-4 text-right">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody id="services-tbody" class="divide-y divide-slate-100 text-xs">
                                    <tr>
                                        <td colspan="4" class="p-8 text-center text-slate-400">Memuat data...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Calculator Panel -->
                    <div id="ptab-calculator" class="space-y-4 hidden">
                        <div class="bg-white rounded-3xl border border-slate-200/80 shadow-sm p-6 space-y-4">
                            <div>
                                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Simulasi Harga
                                    Custom</h3>
                                <p class="text-[10px] text-slate-400 mt-0.5">Pilih item & atur jumlahnya untuk
                                    menghitung estimasi harga modal sebelum membuat paket baru.</p>
                            </div>
                            <div id="calc-services-list" class="space-y-3"></div>
                            <div class="border-t border-slate-100 pt-4 flex items-center justify-between">
                                <div>
                                    <p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">Estimasi
                                        Biaya Modal</p>
                                    <p class="serif-title text-2xl font-extrabold text-slate-900 mt-0.5"
                                        id="calc-total">Rp 0</p>
                                </div>
                                <button onclick="calculateSelectedServices()"
                                    class="rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 text-xs font-bold transition shadow-sm">Hitung
                                    Sekarang</button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- MODAL: ADD SERVICE -->
                <div id="service-modal"
                    class="hidden fixed inset-0 z-50 bg-slate-900/60 flex items-center justify-center p-4">
                    <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full p-8 space-y-5">
                        <h3 class="serif-title text-lg font-bold text-slate-900" id="service-modal-title">Tambah Layanan
                            Baru</h3>
                        <form id="service-form" onsubmit="saveService(event)" class="space-y-4">
                            <input type="hidden" id="service-modal-id">
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase mb-1">Nama
                                    Layanan</label>
                                <input type="text" id="service-modal-name" required placeholder="Contoh: Fotografi Akad"
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900">
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-semibold text-slate-700 uppercase mb-1">Kategori</label>
                                <select id="service-modal-category"
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900">
                                    <option value="Output Fisik">Output Fisik</option>
                                    <option value="Output Digital">Output Digital</option>
                                </select>
                            </div>
                            <div id="service-modal-price-container">
                                <label class="block text-xs font-semibold text-slate-700 uppercase mb-1">Harga Dasar
                                    (Rp)</label>
                                <input type="number" id="service-modal-price" required min="0"
                                    placeholder="Contoh: 1500000"
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase mb-1">Deskripsi
                                    (opsional)</label>
                                <textarea id="service-modal-desc" rows="2"
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-xs focus:outline-none focus:ring-1 focus:ring-slate-900"></textarea>
                            </div>
                            <div class="flex gap-3 pt-2">
                                <button type="button" onclick="closeServiceModal()"
                                    class="w-1/2 py-2.5 rounded-xl border border-slate-300 text-xs font-semibold text-slate-600 hover:bg-slate-50">Batal</button>
                                <button type="submit"
                                    class="w-1/2 py-2.5 rounded-xl bg-slate-900 text-white text-xs font-semibold hover:bg-slate-800 transition">Simpan</button>
                            </div>
                        </form>
                    </div>
                </div>

