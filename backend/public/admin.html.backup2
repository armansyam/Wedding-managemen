                        <p class="text-xs text-slate-500 mt-1">Konfirmasi status DP dan pelunasan secara manual untuk
                            setiap booking aktif.</p>
                    </div>

                    <!-- Filter bar -->
                    <div class="flex flex-wrap gap-2 items-center">
