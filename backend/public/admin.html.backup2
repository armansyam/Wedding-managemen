                            class="block text-xs font-bold text-slate-600 uppercase tracking-widest">Nominal Uang Masuk
                            Riil (Editable)</label>
                        <input type="number" id="payment-modal-amount-input" required placeholder="Contoh: 2000000"
                            class="w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm focus:border-slate-900 focus:outline-none transition">
                    </div>
                </div>

                <!-- Discount Info Section (shown when discount_amount > 0) -->
                <div id="payment-discount-section"
                    class="hidden bg-amber-50 border border-amber-200 rounded-xl p-3 space-y-1">
                    <p class="text-[10px] font-bold text-amber-700 uppercase tracking-widest">Potongan Harga Klien</p>
                    <div class="flex justify-between items-center">
                        <span class="text-xs text-slate-700">Nilai Potongan Diminta:</span>
                        <span id="payment-discount-amount" class="font-bold text-amber-700 text-sm">Rp 0</span>
                    </div>
                    <div id="payment-discount-status-row" class="flex justify-between items-center">
                        <span class="text-xs text-slate-500">Status:</span>
