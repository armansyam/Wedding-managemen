                                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">Sebelum
                                    Perubahan</p>
                                <pre id="audit-before-json"
                                    class="text-xs bg-slate-50 border border-slate-200 rounded-xl p-4 overflow-auto max-h-60 whitespace-pre-wrap text-slate-700"></pre>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold uppercase tracking-wider text-emerald-600 mb-2">Sesudah
                                    Perubahan</p>
                                <pre id="audit-after-json"
                                    class="text-xs bg-emerald-50 border border-emerald-200 rounded-xl p-4 overflow-auto max-h-60 whitespace-pre-wrap text-slate-700"></pre>
                            </div>
                        </div>
                        <button onclick="closeAuditDetailModal()"
                            class="w-full py-3 rounded-xl bg-slate-900 text-white text-xs font-bold hover:bg-slate-800 transition">Tutup</button>
                    </div>
