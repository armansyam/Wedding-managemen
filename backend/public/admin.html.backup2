                        <p class="text-xs text-slate-500 mt-1">Rekaman historis semua perubahan data administratif.</p>
                    </div>

                    <!-- Filter bar -->
                    <div class="flex flex-wrap gap-2 items-center">
                        <select id="audit-table-filter"
                            class="rounded-lg border border-slate-200 px-3 py-2 bg-white text-xs font-medium focus:outline-none">
