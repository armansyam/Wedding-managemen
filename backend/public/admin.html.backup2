    <!-- MODAL: PAYMENT VERIFICATION (SPLIT SCREEN LAYOUT) -->
    <div id="payment-modal"
        class="hidden fixed inset-0 z-50 overflow-y-auto bg-slate-900/60 flex items-center justify-center p-4">
        <div
