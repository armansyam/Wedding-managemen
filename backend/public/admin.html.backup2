                        <div class="space-y-3 text-sm">
                            <div class="flex justify-between items-center pb-2 border-b border-white/10">
                                <span>Total Harga Deal</span>
                                <span id="inv-total" class="font-bold">Rp 0</span>
                            </div>
                            <div class="flex justify-between items-center pb-2 border-b border-white/10">
                                <span>DP Dibayar</span>
                                <span id="inv-dp" class="font-bold text-emerald-400">- Rp 0</span>
                            </div>
                            <div class="flex justify-between items-center pt-2">
                                <span class="font-bold text-lg">Sisa Pelunasan</span>
                                <span id="inv-sisa" class="font-black text-xl text-yellow-400">Rp 0</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center text-[10px] text-slate-400">
                    Sisi Kiri: Informasi Penagihan & Validasi
                </div>
            </div>

            <!-- Right Side: Action form -->
            <div class="md:w-1/2 p-8 flex flex-col justify-between bg-white relative">
                <!-- Close Button -->
                <button onclick="closePaymentModal()" type="button"
                    class="absolute top-6 right-6 text-slate-400 hover:text-slate-700 text-2xl font-bold transition">&times;</button>

                <div class="space-y-6">
                    <div>
                        <span id="payment-modal-badge"
                            class="inline-block bg-blue-50 text-blue-600 text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded">DP
                            Verification</span>
